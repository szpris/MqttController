<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MQTT 远程控制器"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="8dp"
            android:textColor="@color/purple_700" />

        <!-- 连接状态 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textSize="15sp"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/bg_status"
            android:layout_marginBottom="10dp" />

        <!-- 配置卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="3dp"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="Broker"
                        android:textSize="13sp"
                        android:textColor="@color/purple_500" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBroker"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textUri"
                        android:hint="uc.nasi.cn"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="端口"
                        android:textSize="13sp"
                        android:textColor="@color/purple_500" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPort"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:hint="51883"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="Client ID"
                        android:textSize="13sp"
                        android:textColor="@color/purple_500"
                        android:layout_marginStart="10dp" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etClientId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="android_controller"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 连接 / 断开 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="连接"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                app:backgroundTint="@color/purple_500" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDisconnect"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="断开"
                android:enabled="false"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                app:backgroundTint="#FF5252" />
        </LinearLayout>

        <!-- ====== 应用控制 9宫格 ====== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="应用控制"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- 第1行 app1 app2 app3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <!-- app1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app1" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart1" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop1" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- app2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app2" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart2" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop2" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- app3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app3" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart3" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop3" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- 第2行 app4 app5 app6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <!-- app4 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app4" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart4" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop4" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- app5 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app5" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart5" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop5" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- app6 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app6" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart6" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop6" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- 第3行 app7 app8 app9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- app7 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app7" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart7" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop7" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- app8 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app8" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart8" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop8" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- app9 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="app9" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/purple_700" android:layout_marginBottom="4dp"/>
                    <Button android:id="@+id/btnStart9" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="START" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" android:layout_marginBottom="3dp"/>
                    <Button android:id="@+id/btnStop9" android:layout_width="match_parent"
                        android:layout_height="34dp" android:text="STOP" android:textSize="11sp"
                        android:enabled="false" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- 日志 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="运行日志"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearLog"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清空"
                android:textSize="12sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#F5F5F5">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="#333333" />
        </ScrollView>

    </LinearLayout>
</ScrollView>
